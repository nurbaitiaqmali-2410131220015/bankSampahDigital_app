<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F7F4"
    android:padding="16dp">

    <!-- BAGIAN ATAS: Judul Halaman & Status -->
    <TextView
        android:id="@+id/tvJudul"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tugas Penjemputan"
        android:textStyle="bold"
        android:textSize="22sp"
        android:textColor="@android:color/black"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SIAP DIANGKUT"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:background="@drawable/bg_status_orange"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"/>

    <!-- KONTEN UTAMA: Peta dan Kartu Informasi terbungkus RelativeLayout -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp">

        <!-- Peta (Menggunakan CardView agar ujungnya melengkung/rounded) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardMap"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <!-- Ganti dengan com.google.android.gms.maps.MapView saat integrasi kode -->
            <View
                android:id="@+id/mapView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#D1E4D1" />
        </androidx.cardview.widget.CardView>

        <!-- Kartu Detail Alamat & Sampah (Menumpuk di atas peta bagian bawah) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_margin="12dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp"
                android:background="@android:color/white">

                <TextView
                    android:id="@+id/tvNamaWarga"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Warga: Bpk. Budi Santoso"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@android:color/black"/>

                <TextView
                    android:id="@+id/tvNoTelp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="(0812-3456-xxxx)"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="@android:color/black"/>

                <TextView
                    android:id="@+id/tvAlamat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Griya Harmoni Blok C No. 5, RT 02/05"
                    android:textSize="12sp"
                    android:textColor="#777777"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="8dp"/>

                <!-- Divider Line -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EAEAEA"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvDetailSampah"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Plastik PET (~4 Kg)\n• Kardus (~8 Kg)\n• Logam (~2 Kg)"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="3dp"
                    android:textColor="@android:color/black"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </RelativeLayout>

    <!-- BAGIAN BAWAH: Tombol Aksi Ganda -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/btnBukaPeta"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Buka Peta"
            android:textColor="#00AA13"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginRight="6dp"
            android:backgroundTint="#E5F6EC"
            app:cornerRadius="12dp"/>

        <Button
            android:id="@+id/btnSelesaiAngkut"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Selesai Angkut"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginLeft="6dp"
            android:backgroundTint="#007A20"
            app:cornerRadius="12dp"/>
    </LinearLayout>

</LinearLayout>