<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Input Sampah"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etNamaSampah"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:background="@android:drawable/editbox_background"
            android:hint="Masukkan nama sampah (misal: Botol Plastik)"
            android:paddingLeft="15dp"
            android:inputType="text"
            android:importantForAutofill="no" />

        <EditText
            android:id="@+id/etJenisKategori"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:background="@android:drawable/editbox_background"
            android:hint="Masukkan jenis sampah (misal: Anorganik)"
            android:paddingLeft="15dp"
            android:inputType="text"
            android:importantForAutofill="no" />

        <EditText
            android:id="@+id/etBeratSampah"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:background="@android:drawable/editbox_background"
            android:hint="Masukkan berat sampah (kg)"
            android:inputType="numberDecimal"
            android:paddingLeft="15dp"
            android:importantForAutofill="no" />

        <Button
            android:id="@+id/btnHitung"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/accent_yellow"
            android:text="Hitung Total Harga"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:paddingHorizontal="30dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:text="Hasil Kalkulasi"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:textSize="16sp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="15dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Komoditas:"
                            android:textColor="#7F8C8D"
                            android:textSize="14sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Status Estimasi:"
                            android:textColor="#7F8C8D"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:gravity="end"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Pendapatan"
                            android:textSize="12sp"
                            android:textColor="#555555" />
                        <TextView
                            android:id="@+id/tvTotalHargaEstimasi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Rp. -"
                            android:textStyle="bold"
                            android:textColor="@color/black"
                            android:textSize="18sp"
                            tools:text="Rp. 15.000" />
                    </LinearLayout>
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/etNamaBankSampah"
                        android:layout_width="0dp"
                        android:layout_height="45dp"
                        android:layout_weight="1.4"
                        android:background="#EFEFEF"
                        android:hint="Nama Bank Sampah Tujuan"
                        android:textSize="12sp"
                        android:paddingLeft="12dp"
                        android:inputType="text"
                        android:importantForAutofill="no" />

                    <Button
                        android:id="@+id/btnSetorJemput"
                        android:layout_width="0dp"
                        android:layout_height="45dp"
                        android:layout_weight="1"
                        android:layout_marginLeft="10dp"
                        android:backgroundTint="@color/accent_yellow"
                        android:text="Setor Dan Jemput"
                        android:textSize="11sp"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:padding="0dp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>